# Hajime-AI-Bot 環境変数テンプレート
# このファイルをコピーして .env を作り、各値を埋める。
# .env は git 管理外(.gitignore で除外)。

# --- Discord -----------------------------------------------------------
# Bot Token: Discord Developer Portal で発行(Hajime AI Juku アプリ)
DISCORD_BOT_TOKEN=

# 招待先サーバー(TaishiのX運用 と同じ)
DISCORD_GUILD_ID=1500753755019280416

# チャンネル ID(古谷さんがチャンネル作成後に Discord 上で右クリック → チャンネル ID をコピー)
DISCORD_CHANNEL_CURATION=
DISCORD_CHANNEL_BASICS=
DISCORD_CHANNEL_BUZZ=
DISCORD_CHANNEL_SYSTEM_LOGS=

# --- Anthropic ---------------------------------------------------------
# 既存 Xapp と共用可能。残高消費は両者合算で見る
ANTHROPIC_API_KEY=

# --- X API (read-only) -------------------------------------------------
# 既存 Pay-Per-Use アカウント($4.58 残)を共用するか、
# AI 塾用に新規 Bearer Token を発行するか判断
X_BEARER_TOKEN=
